{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/server.mjs": {
      "runtime": "@vercel/node@5.1.10",
      "includeFiles": "dist/server/**"
    }
  },
  "rewrites": [
    { "source": "/((?!_build/|assets/|favicon\\.svg|robots\\.txt|logo\\.png).*)", "destination": "/api/server" }
  ]
}
